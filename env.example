# Pastas (mantém seus nomes originais)
TEMPLATE_FOLDER=views
STATIC_FOLDER=public

# Flask / segurança
SECRET_KEY=P3tG0$ecretK3y

# Banco
SQLALCHEMY_DATABASE_URI=sqlite:///gestor.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Semeadura inicial
SEED_ON_STARTUP=true

# Ramo de negócio: lavajato | generico
# Define quais módulos opcionais são ativados (ex.: 'veiculo' só em lavajato).
# É escrito pelo instalador conforme a escolha do usuário.
BUSINESS_TYPE=generico

# Módulo de estoque (produtos com campos customizáveis).
# Independente do ramo: o usuário escolhe no instalador.
ENABLE_ESTOQUE=true
